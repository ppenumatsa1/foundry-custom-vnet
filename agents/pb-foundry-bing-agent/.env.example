AZURE_AI_PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
PROJECT_ENDPOINT=https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_AGENT_ID=pb-bing-agent
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5

# Optional. If true, creates/updates a local Foundry agent version with web search tool.
CREATE_AGENT_IF_MISSING=true

# Optional web search tuning for auto-created agent version.
WEB_SEARCH_CONTEXT_SIZE=medium
WEB_SEARCH_COUNTRY=
WEB_SEARCH_REGION=
WEB_SEARCH_CITY=
WEB_SEARCH_TIMEZONE=
